<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>bellwether: methodology</title>
<script>
(function() {
  var stored = localStorage.getItem('bw-theme');
  var sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', stored || sys);
})();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    color-scheme: light dark;
    --fg: #1a1a1a; --bg: #fcfcfc; --surface: #ffffff; --muted: #5a5a5a;
    --accent: #0066cc; --border: #e0e0e0; --border-strong: #c0c0c0;
    --code-bg: rgba(127,127,127,0.10);
    --purple: #6d28d9;
  }
  [data-theme="dark"] {
    --fg: #e8e8e8; --bg: #0f0f0f; --surface: #181818; --muted: #999;
    --accent: #6db3ff; --border: #2a2a2a; --border-strong: #3a3a3a;
    --purple: #a78bfa;
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; line-height: 1.6; color: var(--fg); background: var(--bg); margin: 0; padding: 0; }

  h1, h2, h3, h4 { font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; font-weight: 600; letter-spacing: -0.005em; }

  header, footer { max-width: 1180px; margin: 0 auto; padding: 1rem; }
  .layout { max-width: 1180px; margin: 0 auto; padding: 0 1rem; display: grid; grid-template-columns: 220px 1fr; gap: 2rem; align-items: start; }

  header { padding-top: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
  h1 { margin: 0; font-size: 1.9rem; letter-spacing: -0.01em; color: var(--purple); font-weight: 700; }
  h1 a { color: inherit; text-decoration: none; }
  nav a { color: var(--accent); text-decoration: none; margin-right: 1.25rem; font-weight: 500; }
  nav a:hover { text-decoration: underline; }

  aside { position: sticky; top: 1rem; max-height: calc(100vh - 2rem); overflow-y: auto; padding: 1rem 0; font-size: 0.88rem; }
  aside h2 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; color: var(--muted); margin: 0 0 0.5rem 0; padding: 0; border: none; }
  aside .toc ul { list-style: none; padding: 0; margin: 0; }
  aside .toc ul ul { padding-left: 0.85rem; margin-top: 0.25rem; }
  aside .toc li { margin: 0.25rem 0; }
  aside .toc a { color: var(--fg); text-decoration: none; display: block; padding: 0.15rem 0.5rem; }
  aside .toc a:hover { background: rgba(127,127,127,0.08); color: var(--accent); }

  main { max-width: 760px; padding: 0; }
  main h1, main h2, main h3, main h4 { scroll-margin-top: 1rem; }
  main h1 { font-size: 1.7rem; margin-top: 0; color: var(--fg); font-weight: 600; }
  main h2 { margin-top: 2.25rem; padding-bottom: 0.25rem; border-bottom: 1px solid var(--border); font-size: 1.4rem; }
  main h3 { margin-top: 1.5rem; font-size: 1.15rem; }
  main h4 { margin-top: 1.25rem; font-size: 1rem; color: var(--muted); }

  code { font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace; background: var(--code-bg); padding: 0.05rem 0.3rem; font-size: 0.9em; }
  pre { background: var(--code-bg); padding: 0.75rem 1rem; overflow-x: auto; font-size: 0.88rem; line-height: 1.45; }
  pre code { background: transparent; padding: 0; font-size: inherit; }
  table { border-collapse: collapse; margin: 1rem 0; font-size: 0.92rem; width: 100%; }
  th, td { padding: 0.45rem 0.75rem; text-align: left; border: 1px solid var(--border); vertical-align: top; }
  th { background: var(--code-bg); font-weight: 600; font-family: 'Montserrat', sans-serif; }
  blockquote { margin: 1rem 0; padding: 0.5rem 1rem; border-left: 3px solid var(--border); color: var(--muted); background: rgba(127,127,127,0.04); }
  ul, ol { padding-left: 1.5rem; }
  hr { border: 0; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  a { color: var(--accent); }
  a:hover { text-decoration: underline; }

  footer { margin-top: 3.5rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem; }

  #theme-toggle {
    position: fixed; top: 0.75rem; right: 1rem;
    width: 30px; height: 30px;
    background: transparent; border: 1px solid var(--border);
    color: var(--muted); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: color 0.15s ease, border-color 0.15s ease;
    padding: 0; z-index: 100;
  }
  #theme-toggle:hover { color: var(--fg); border-color: var(--border-strong); }
  #theme-toggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  #theme-toggle svg { display: none; width: 15px; height: 15px; }
  [data-theme="dark"] #theme-toggle .icon-sun { display: block; }
  [data-theme="light"] #theme-toggle .icon-moon { display: block; }

  @media (max-width: 880px) {
    .layout { grid-template-columns: 1fr; gap: 1rem; }
    aside { position: static; max-height: none; padding: 0.5rem 0; border-bottom: 1px solid var(--border); }
    aside .toc { font-size: 0.85rem; }
  }
</style>
</head>
<body>

<button id="theme-toggle" type="button" aria-label="Toggle color scheme" title="Toggle color scheme">
  <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
  </svg>
  <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<header>
  <h1><a href="index.html">bellwether</a></h1>
  <nav>
    <a href="index.html">Leaderboard</a>
    <a href="glossary.html">Glossary</a>
    <a href="https://github.com/cartesianxr7/bellwether">GitHub</a>
  </nav>
</header>

<div class="layout">
  <aside>
    <h2>Contents</h2>
    <div class="toc">{{ methodology_toc_html|safe }}</div>
  </aside>
  <main>
    {{ methodology_html_body|safe }}
  </main>
</div>

<footer>
  <p>methodology version {{ methodology_version }}</p>
</footer>

<script>
  document.getElementById('theme-toggle').addEventListener('click', function() {
    var root = document.documentElement;
    var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('bw-theme', next);
  });
</script>

</body>
</html>
