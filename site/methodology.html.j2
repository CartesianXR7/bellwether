<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>bellwether: methodology</title>
<style>
  :root { color-scheme: light dark; --fg: #1a1a1a; --bg: #fafafa; --muted: #666; --accent: #0066cc; --border: #ddd; --code-bg: rgba(127,127,127,0.12); }
  @media (prefers-color-scheme: dark) {
    :root { --fg: #e8e8e8; --bg: #161616; --muted: #999; --accent: #6db3ff; --border: #333; }
  }
  * { box-sizing: border-box; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; line-height: 1.6; color: var(--fg); background: var(--bg); margin: 0; padding: 1rem; }
  main, header, footer { max-width: 760px; margin-left: auto; margin-right: auto; }
  header { padding-bottom: 1rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
  h1 { margin: 0 0 0.25rem 0; font-size: 1.75rem; }
  h1 a { color: var(--fg); text-decoration: none; }
  h2 { margin-top: 2.25rem; padding-bottom: 0.25rem; border-bottom: 1px solid var(--border); }
  h3 { margin-top: 1.5rem; }
  nav a { color: var(--accent); text-decoration: none; margin-right: 1rem; }
  nav a:hover { text-decoration: underline; }
  code { font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace; background: var(--code-bg); padding: 0.05rem 0.3rem; border-radius: 3px; font-size: 0.9em; }
  pre { background: var(--code-bg); padding: 0.75rem; border-radius: 4px; overflow-x: auto; }
  pre code { background: transparent; padding: 0; }
  table { border-collapse: collapse; margin: 1rem 0; font-size: 0.95em; }
  th, td { padding: 0.4rem 0.75rem; text-align: left; border: 1px solid var(--border); }
  th { background: var(--code-bg); font-weight: 600; }
  blockquote { margin: 1rem 0; padding-left: 1rem; border-left: 3px solid var(--border); color: var(--muted); }
  ul, ol { padding-left: 1.5rem; }
  hr { border: 0; border-top: 1px solid var(--border); margin: 2rem 0; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem; }
</style>
</head>
<body>

<header>
  <h1><a href="index.html">bellwether</a></h1>
  <nav>
    <a href="index.html">Leaderboard</a>
    <a href="https://github.com/cartesianxr7/bellwether">GitHub</a>
  </nav>
</header>

<main>
{{ methodology_html_body|safe }}
</main>

<footer>
  <p>methodology version {{ methodology_version }}</p>
</footer>

</body>
</html>
