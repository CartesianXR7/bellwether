<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>bellwether: cost-and-failure-mode benchmark for LLM agents</title>
<meta name="description" content="Cross-provider LLM agent benchmark. Total Cost of Task, failure-mode taxonomy, machine-checkable ground truth.">
<script>
(function() {
  var stored = localStorage.getItem('bw-theme');
  var sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', stored || sys);
})();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    color-scheme: light dark;
    --fg: #1a1a1a; --bg: #fcfcfc; --surface: #ffffff; --muted: #5a5a5a;
    --accent: #0066cc; --accent-soft: #e6f0ff;
    --border: #e0e0e0; --border-strong: #c0c0c0;
    --dirty: #b54708; --dirty-bg: #fff8eb;
    --good: #117a3c; --good-bg: #e8f7ed;
    --bar-bg: #ececec; --bar-fill: #5a93d6;
    --tied: #888;
    --purple: #6d28d9;
    --prov-anthropic: #c9764e;
    --prov-openai: #10a37f;
    --prov-google: #4285f4;
    --prov-xai: #555555;
    --prov-perplexity: #20a5b8;
    --prov-openrouter: #e6633a;
    --class-reasoning-fg: #5b21b6;
    --class-reasoning-bg: #ede9fe;
    --class-search-fg: #92400e;
    --class-search-bg: #fef3c7;
    --class-standard-fg: #4a4a4a;
    --class-standard-bg: #f1f1f1;
  }
  [data-theme="dark"] {
    --fg: #e8e8e8; --bg: #0f0f0f; --surface: #181818; --muted: #999;
    --accent: #6db3ff; --accent-soft: #1a2a3f;
    --border: #2a2a2a; --border-strong: #3a3a3a;
    --dirty: #f7b955; --dirty-bg: #2a1c08;
    --good: #4ec97a; --good-bg: #0f2316;
    --bar-bg: #2a2a2a; --bar-fill: #4a73a8;
    --tied: #777;
    --purple: #a78bfa;
    --prov-xai: #aaaaaa;
    --class-reasoning-fg: #c4b5fd;
    --class-reasoning-bg: #2a1f4a;
    --class-search-fg: #fcd34d;
    --class-search-bg: #3a2a08;
    --class-standard-fg: #aaaaaa;
    --class-standard-bg: #2a2a2a;
  }
  * { box-sizing: border-box; }
  html { -webkit-text-size-adjust: 100%; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; line-height: 1.5; color: var(--fg); background: var(--bg); margin: 0; padding: 1rem; }
  main, header, footer { max-width: 1100px; margin-left: auto; margin-right: auto; }

  h1, h2, h3, h4 { font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; font-weight: 600; letter-spacing: -0.005em; }

  header { padding: 1.5rem 0 1rem 0; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
  h1 { margin: 0; font-size: 1.9rem; letter-spacing: -0.01em; color: var(--purple); font-weight: 700; }
  .tagline { color: var(--muted); margin: 0.25rem 0 0.75rem 0; font-size: 1.05rem; }
  nav a { color: var(--accent); text-decoration: none; margin-right: 1.25rem; font-weight: 500; }
  nav a:hover { text-decoration: underline; }

  .intro { padding: 1rem 0 0.5rem 0; max-width: 760px; }
  .intro p { margin: 0.5rem 0; }
  .intro code, .intro-code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; background: rgba(127,127,127,0.12); padding: 0.05rem 0.3rem; font-size: 0.92em; }

  h2 { margin: 2.5rem 0 0.5rem 0; font-size: 1.3rem; padding-bottom: 0.25rem; border-bottom: 1px solid var(--border); }
  h2 a { color: inherit; text-decoration: none; }
  h2 .task-link { color: var(--accent); font-size: 0.85rem; font-weight: 500; margin-left: 0.75rem; }
  h3 { margin: 1.25rem 0 0.5rem 0; font-size: 1rem; color: var(--muted); font-weight: 600; }

  .pass-meta {
    font-size: 0.85rem; color: var(--muted); display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 1rem;
    margin: 1rem 0 0.5rem 0;
  }
  .pass-meta code { font-size: 0.85em; }
  .badge { display: inline-block; font-size: 0.75rem; padding: 0.1rem 0.5rem; border: 1px solid currentColor; }
  .badge-dirty { color: var(--dirty); background: var(--dirty-bg); }
  .badge-clean { color: var(--good); background: var(--good-bg); }

  .leaderboard-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  th, td { padding: 0.55rem 0.75rem; text-align: left; border-bottom: 1px solid var(--border); vertical-align: middle; }
  th { font-weight: 600; font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; background: var(--surface); font-family: 'Montserrat', sans-serif; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
  td.rank { font-weight: 600; color: var(--accent); width: 2.5rem; }
  tbody tr:hover { background: rgba(127,127,127,0.04); }
  tr.dirty { background: var(--dirty-bg); }
  tr.dirty:hover { background: var(--dirty-bg); }
  tr.dirty td.rank { color: var(--dirty); }
  tr.dirty td.rank::before { content: "*"; }
  tr.tied td.rank::after { content: " ≈"; color: var(--tied); font-weight: normal; }

  .prov { display: inline-flex; align-items: center; gap: 0.5rem; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.92em; }
  .prov-swatch { display: inline-block; width: 8px; height: 8px; flex-shrink: 0; }
  .prov.provider-anthropic .prov-swatch { background: var(--prov-anthropic); }
  .prov.provider-openai .prov-swatch { background: var(--prov-openai); }
  .prov.provider-google .prov-swatch { background: var(--prov-google); }
  .prov.provider-xai .prov-swatch { background: var(--prov-xai); }
  .prov.provider-perplexity .prov-swatch { background: var(--prov-perplexity); }
  .prov.provider-openrouter .prov-swatch { background: var(--prov-openrouter); }

  /* model_class chip: surfaces reasoning vs search vs standard so cross-class
     comparisons are visually flagged (METHODOLOGY s2.7). Standard is rendered
     low-contrast since it is the default. */
  .class-chip { display: inline-block; font-size: 0.66rem; padding: 0.05rem 0.35rem; margin-left: 0.5rem; letter-spacing: 0.5px; text-transform: uppercase; font-weight: 600; vertical-align: middle; }
  .class-chip.class-reasoning { color: var(--class-reasoning-fg); background: var(--class-reasoning-bg); }
  .class-chip.class-search { color: var(--class-search-fg); background: var(--class-search-bg); }
  .class-chip.class-standard { display: none; }
  .class-note { font-size: 0.78rem; color: var(--muted); margin: 0.25rem 0 0.75rem 0; }
  .class-note .class-chip { display: inline-block; margin: 0 0.25rem; }

  .cost-cell { min-width: 11rem; }
  .cost-bar-wrap { display: flex; align-items: center; gap: 0.6rem; }
  .cost-bar { flex: 0 0 60px; height: 6px; background: var(--bar-bg); overflow: hidden; }
  .cost-bar > div { height: 100%; background: var(--bar-fill); }
  .cost-value { font-variant-numeric: tabular-nums; }
  .cost-std { color: var(--muted); font-size: 0.85em; margin-left: 0.15rem; }

  .fm-list { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .fm-pill { display: inline-block; font-size: 0.72rem; padding: 0.1rem 0.4rem; background: rgba(127,127,127,0.1); color: var(--muted); white-space: nowrap; }
  .fm-pill strong { color: var(--fg); margin-right: 0.2rem; }

  .calc { background: var(--accent-soft); border: 1px solid var(--accent); padding: 1rem 1.25rem; margin: 1.5rem 0; }
  .calc h3 { margin: 0 0 0.5rem 0; color: var(--accent); }
  .calc label { display: block; margin-bottom: 0.5rem; font-size: 0.92rem; }
  .calc input[type="number"] { font: inherit; padding: 0.3rem 0.5rem; width: 10rem; border: 1px solid var(--border-strong); background: var(--surface); color: var(--fg); }
  .calc-output { margin-top: 0.5rem; font-size: 0.88rem; color: var(--muted); }
  .calc table { margin-top: 0.5rem; }
  .calc th, .calc td { padding: 0.3rem 0.6rem; font-size: 0.85rem; }

  footer { margin-top: 3.5rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem; }
  footer a { color: var(--accent); text-decoration: none; }
  footer a:hover { text-decoration: underline; }

  .empty { color: var(--muted); font-style: italic; padding: 2.5rem 0; text-align: center; }

  /* Top-of-page stats strip */
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1px;
    margin: 1.5rem 0 2.5rem 0;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .stat { background: var(--surface); padding: 0.95rem 1.1rem; }
  .stat .num { font-family: 'Montserrat', sans-serif; font-size: 1.55rem; font-weight: 700; color: var(--fg); line-height: 1.15; }
  .stat .label { font-size: 0.72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.6px; margin-top: 0.3rem; font-family: 'Montserrat', sans-serif; }

  /* Cross-task ranking matrix overview */
  .overview { margin: 0 0 3rem 0; }
  .overview h2 { font-size: 1.15rem; margin-top: 0; border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; }
  .overview p.note { font-size: 0.82rem; color: var(--muted); margin: 0.5rem 0 0.75rem 0; }
  .ranking-matrix th.task-col, .ranking-matrix td.rank-cell { text-align: center; min-width: 7rem; }
  .ranking-matrix th.task-col a { color: var(--muted); text-decoration: none; }
  .ranking-matrix th.task-col a:hover { color: var(--accent); text-decoration: underline; }
  .ranking-matrix td.rank-cell { font-variant-numeric: tabular-nums; font-weight: 500; }
  .ranking-matrix td.rank-1 { background: rgba(109, 40, 217, 0.18); color: var(--purple); font-weight: 700; }
  .ranking-matrix td.rank-2 { background: rgba(109, 40, 217, 0.10); font-weight: 600; }
  .ranking-matrix td.rank-3 { background: rgba(109, 40, 217, 0.05); }
  .ranking-matrix td.rank-na { color: var(--muted); }
  [data-theme="dark"] .ranking-matrix td.rank-1 { background: rgba(167, 139, 250, 0.22); color: var(--purple); }
  [data-theme="dark"] .ranking-matrix td.rank-2 { background: rgba(167, 139, 250, 0.13); }
  [data-theme="dark"] .ranking-matrix td.rank-3 { background: rgba(167, 139, 250, 0.06); }

  /* Per-task sections: heavier visual separation, accent stripe, headline color */
  .task-section { margin-top: 4.5rem; padding-top: 2.5rem; border-top: 2px solid var(--border-strong); position: relative; }
  .task-section::before { content: ""; position: absolute; left: -1rem; top: 2.5rem; bottom: 0; width: 3px; background: var(--purple); opacity: 0.6; }
  .task-section h2 { margin-top: 0; font-size: 1.55rem; font-weight: 700; color: var(--purple); padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
  .task-section h2 a { color: inherit; text-decoration: none; }
  .task-section h2 a code { color: var(--purple); background: transparent; padding: 0; }
  .task-section h2 a:hover { text-decoration: underline; }
  .task-section h2 .task-link { color: var(--accent); font-size: 0.85rem; font-weight: 500; margin-left: 0.75rem; }

  /* Theme toggle: minimal, far top right, fixed position */
  #theme-toggle {
    position: fixed; top: 0.75rem; right: 1rem;
    width: 30px; height: 30px;
    background: transparent; border: 1px solid var(--border);
    color: var(--muted); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: color 0.15s ease, border-color 0.15s ease;
    padding: 0; z-index: 100;
  }
  #theme-toggle:hover { color: var(--fg); border-color: var(--border-strong); }
  #theme-toggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  #theme-toggle svg { display: none; width: 15px; height: 15px; }
  [data-theme="dark"] #theme-toggle .icon-sun { display: block; }
  [data-theme="light"] #theme-toggle .icon-moon { display: block; }

  @media (max-width: 640px) {
    body { padding: 0.75rem; }
    h1 { font-size: 1.5rem; }
    h2 { font-size: 1.15rem; }
    th, td { padding: 0.4rem 0.5rem; font-size: 0.9rem; }
    .cost-bar { flex: 0 0 40px; }
    .pass-meta { gap: 0.4rem; }
  }
</style>
</head>
<body>

<button id="theme-toggle" type="button" aria-label="Toggle color scheme" title="Toggle color scheme">
  <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
  </svg>
  <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<header>
  <h1>bellwether</h1>
  <p class="tagline">The cost-and-failure-mode benchmark for LLM agents.</p>
  <nav>
    <a href="methodology.html">Methodology</a>
    <a href="glossary.html">Glossary</a>
    <a href="https://github.com/cartesianxr7/bellwether">GitHub</a>
    <a href="https://pypi.org/project/bellwether/">PyPI</a>
  </nav>
</header>

<main>

<section class="intro">
  <p>
    <strong>Headline metric: <span class="intro-code">effective_TCoT</span></strong>
    is total spend per successful task completion, including the cost of failed
    retries. Lower is better. The methodology is the contribution; the leaderboard
    is its proof.
  </p>
  <p>
    Validation is machine-checkable (no LLM-as-judge). Failures are classified
    into eight modes (refusal, confabulation, schema break, truncation, partial,
    off-task, timeout, error). One canonical prompt per task across all providers.
    Temperature 0; N=3 runs per task instance; cost-per-million-token pricing
    verified per provider.
  </p>
  <p>
    See the <a href="methodology.html">full methodology</a> for formulas, retry
    policy, validator contract, and reproducibility caveats. New to the metrics?
    The <a href="glossary.html">glossary</a> defines each term.
  </p>
</section>

{% if not tasks %}
<p class="empty">No bench results yet. Run <code>bellwether run</code> and rebuild the site.</p>
{% endif %}

{% if stats %}
<section class="stats" aria-label="Bench summary">
  <div class="stat"><div class="num">{{ stats.n_tasks }}</div><div class="label">tasks benched</div></div>
  <div class="stat"><div class="num">{{ stats.n_models }}</div><div class="label">distinct models</div></div>
  <div class="stat"><div class="num">{{ stats.n_passes }}</div><div class="label">bench passes</div></div>
  <div class="stat"><div class="num">${{ "%.2f"|format(stats.total_spend_usd) }}</div><div class="label">total bench spend</div></div>
</section>
{% endif %}

{% if ranking and ranking.rows %}
<section class="overview" aria-label="Cross-task ranking matrix">
  <h2>Cross-task ranking</h2>
  <p class="note">Each cell is the model's rank on that task in its latest clean pass. Lower is better. Rank 1 highlighted in purple. Rows are grouped by <code>model_class</code> (standard, then <span class="class-chip class-reasoning">reasoning</span>, then <span class="class-chip class-search">search</span>) and sorted within each class by average observed rank. Cross-class comparisons mislead because reasoning models burn 5x to 20x more output tokens per attempt and search models pay an unmetered per-search fee; see <a href="methodology.html#27-model_class">methodology s2.7</a>.</p>
  <div class="leaderboard-wrap">
    <table class="ranking-matrix">
      <thead>
        <tr>
          <th>Provider / Model</th>
          <th>Class</th>
          {% for task_name in ranking.task_order %}
          <th class="task-col"><a href="tasks/{{ task_name }}.html"><code>{{ task_name }}</code></a></th>
          {% endfor %}
          <th class="num">avg rank</th>
        </tr>
      </thead>
      <tbody>
        {% for row in ranking.rows %}
        <tr>
          <td><span class="prov provider-{{ row.provider }}"><span class="prov-swatch"></span>{{ row.provider }}/{{ row.model }}</span></td>
          <td>{% if row.model_class != 'standard' %}<span class="class-chip class-{{ row.model_class }}">{{ row.model_class }}</span>{% else %}<span style="color: var(--muted); font-size: 0.78rem;">standard</span>{% endif %}</td>
          {% for task_name in ranking.task_order %}
          {% if task_name in row.ranks %}
          {% set rk = row.ranks[task_name].rank %}
          <td class="rank-cell rank-{{ rk if rk <= 3 else 'other' }}">#{{ rk }}{% if row.ranks[task_name].infinite %}*{% endif %}</td>
          {% else %}
          <td class="rank-cell rank-na">n/a</td>
          {% endif %}
          {% endfor %}
          <td class="num">{{ "%.1f"|format(row.avg_rank) if row.n_observed else "n/a" }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endif %}

{% for task_name, view in tasks.items() %}

<section class="task-section">
<h2>
  <a href="tasks/{{ task_name }}.html">Task: <code>{{ task_name }}</code></a>
  <a class="task-link" href="tasks/{{ task_name }}.html">detailed page &rsaquo;</a>
</h2>

{% if view.latest_clean %}
{% set headline = view.latest_clean %}
<h3>Latest clean pass &middot; {{ headline.started_at[:19].replace('T', ' ') }} UTC &middot; <code>{{ headline.git_sha_short }}</code></h3>

<div class="leaderboard-wrap">
<table>
  <thead>
    <tr>
      <th>#</th>
      <th>Provider / Model</th>
      <th class="num">Success</th>
      <th class="num">effective_TCoT</th>
      <th class="num">Latency p50 / p95</th>
      <th class="num">1st-try pass</th>
      <th>Failure modes (this pass)</th>
    </tr>
  </thead>
  <tbody>
    {% for entry in headline.entries %}
    <tr {% if entry.git_dirty %}class="dirty"{% elif entry.tied_with_above %}class="tied"{% endif %}
        data-eff-tcot="{{ entry.effective_tcot if not entry.effective_tcot_infinite else 'Infinity' }}">
      <td class="rank">{{ entry.rank }}</td>
      <td>
        <span class="prov provider-{{ entry.provider }}">
          <span class="prov-swatch"></span>{{ entry.provider }}/{{ entry.model }}
        </span>
        <span class="class-chip class-{{ entry.model_class }}">{{ entry.model_class }}</span>
      </td>
      <td class="num">{{ "%.1f"|format(entry.success_rate * 100) }}% ({{ entry.n_successes }}/{{ entry.n_trials }})</td>
      <td class="num cost-cell">
        <div class="cost-bar-wrap">
          <span class="cost-value">
            {% if entry.effective_tcot_infinite %}infinite{% else %}${{ "%.5f"|format(entry.effective_tcot) }}{% endif %}{% if entry.std_tcot_success and not entry.effective_tcot_infinite %}<span class="cost-std">±${{ "%.5f"|format(entry.std_tcot_success) }}</span>{% endif %}
          </span>
          <div class="cost-bar"><div style="width: {{ entry.cost_bar_pct }}%"></div></div>
        </div>
      </td>
      <td class="num">{{ "%.2f"|format(entry.p50) }}s / {{ "%.2f"|format(entry.p95) }}s</td>
      <td class="num">{{ "%.0f"|format(entry.first_attempt_pass_rate * 100) }}% ({{ entry.n_first_attempt_pass }}/{{ entry.n_trials }})</td>
      <td>
        {% if entry.failure_mode_counts %}
        <span class="fm-list">
          {% for mode, count in entry.failure_mode_counts.items()|sort(reverse=true, attribute=1) %}
          <span class="fm-pill"><strong>{{ count }}</strong>{{ mode }}</span>
          {% endfor %}
        </span>
        {% else %}
        <span style="color: var(--muted); font-size: 0.85rem;">none</span>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>

<p style="font-size: 0.82rem; color: var(--muted); margin: 0.5rem 0;">
  Rank rows marked with &ldquo;&approx;&rdquo; are within {{ "%.0f"|format(0.05 * 100) }}% of the rank above on <code>effective_TCoT</code> &mdash; treat as tied within bench noise. See <a href="methodology.html#7-stochasticity-and-multi-run">methodology s7</a>.
</p>

<section class="calc">
  <h3>Cost calculator</h3>
  <label>
    If I run this task
    <input type="number" min="1" step="1" value="10000" id="calc-{{ task_name }}-n"
           oninput="updateCalc('{{ task_name }}', this.value)">
    times per month, monthly cost per provider:
  </label>
  <div class="calc-output">
    <table>
      <thead>
        <tr><th>Provider / Model</th><th class="num">Monthly cost (USD)</th></tr>
      </thead>
      <tbody>
        {% for entry in headline.entries %}
        <tr>
          <td><span class="prov provider-{{ entry.provider }}"><span class="prov-swatch"></span>{{ entry.provider }}/{{ entry.model }}</span><span class="class-chip class-{{ entry.model_class }}">{{ entry.model_class }}</span></td>
          <td class="num" data-calc-task="{{ task_name }}"
              data-calc-eff="{{ entry.effective_tcot if not entry.effective_tcot_infinite else 'Infinity' }}">
            {% if entry.effective_tcot_infinite %}n/a{% else %}${{ "%.2f"|format(entry.effective_tcot * 10000) }}{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <p style="margin: 0.5rem 0 0 0; font-size: 0.78rem;">
      Computed from this pass's <code>effective_TCoT</code>. Real production cost will vary with prompt length, model snapshot drift, and retry distribution on your data.
    </p>
  </div>
</section>

{% endif %}

{% if view.n_passes > 1 %}
<p style="font-size: 0.85rem; color: var(--muted); margin: 0.75rem 0;">
  {{ view.n_passes }} bench passes recorded for this task. Full pass-by-pass breakdown, reproducibility deltas, and per-provider failure-mode aggregates are on the <a href="tasks/{{ task_name }}.html">detailed task page</a>.
</p>
{% endif %}

</section>
{% endfor %}

</main>

<footer>
  <p>
    methodology version {{ methodology_version }}
    &middot; bellwether {{ bellwether_version }}
    &middot; last bench {{ latest_bench_iso[:19].replace('T', ' ') }} UTC
    &middot; {{ n_total_results }} result file{{ '' if n_total_results == 1 else 's' }} loaded
  </p>
  <p>
    <a href="https://github.com/cartesianxr7/bellwether">github.com/cartesianxr7/bellwether</a>
    &middot; <a href="https://pypi.org/project/bellwether/">pip install bellwether</a>
    &middot; MIT license
  </p>
</footer>

<script>
  function updateCalc(task, n) {
    const monthly = parseFloat(n) || 0;
    document.querySelectorAll('td[data-calc-task="' + task + '"]').forEach(function(td) {
      const eff = parseFloat(td.dataset.calcEff);
      if (isFinite(eff)) {
        td.textContent = '$' + (eff * monthly).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
      } else {
        td.textContent = 'n/a';
      }
    });
  }
  document.getElementById('theme-toggle').addEventListener('click', function() {
    var root = document.documentElement;
    var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('bw-theme', next);
  });
</script>

</body>
</html>
