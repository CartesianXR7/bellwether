<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>bellwether: {{ task_name }}</title>
<script>
(function() {
  var stored = localStorage.getItem('bw-theme');
  var sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  document.documentElement.setAttribute('data-theme', stored || sys);
})();
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    color-scheme: light dark;
    --fg: #1a1a1a; --bg: #fcfcfc; --surface: #ffffff; --muted: #5a5a5a;
    --accent: #0066cc; --accent-soft: #e6f0ff;
    --border: #e0e0e0; --border-strong: #c0c0c0;
    --dirty: #b54708; --dirty-bg: #fff8eb;
    --good: #117a3c; --good-bg: #e8f7ed;
    --bar-bg: #ececec; --bar-fill: #5a93d6;
    --tied: #888;
    --purple: #6d28d9;
    --prov-anthropic: #c9764e;
    --prov-openai: #10a37f;
    --prov-google: #4285f4;
    --prov-xai: #555555;
    --prov-perplexity: #20a5b8;
    --prov-openrouter: #e6633a;
    --class-reasoning-fg: #5b21b6;
    --class-reasoning-bg: #ede9fe;
    --class-search-fg: #92400e;
    --class-search-bg: #fef3c7;
  }
  [data-theme="dark"] {
    --fg: #e8e8e8; --bg: #0f0f0f; --surface: #181818; --muted: #999;
    --accent: #6db3ff; --accent-soft: #1a2a3f;
    --border: #2a2a2a; --border-strong: #3a3a3a;
    --dirty: #f7b955; --dirty-bg: #2a1c08;
    --good: #4ec97a; --good-bg: #0f2316;
    --bar-bg: #2a2a2a; --bar-fill: #4a73a8;
    --tied: #777;
    --purple: #a78bfa;
    --prov-xai: #aaaaaa;
    --class-reasoning-fg: #c4b5fd;
    --class-reasoning-bg: #2a1f4a;
    --class-search-fg: #fcd34d;
    --class-search-bg: #3a2a08;
  }
  * { box-sizing: border-box; }
  html { -webkit-text-size-adjust: 100%; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; line-height: 1.5; color: var(--fg); background: var(--bg); margin: 0; padding: 1rem; }
  main, header, footer { max-width: 1100px; margin-left: auto; margin-right: auto; }

  h1, h2, h3, h4 { font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif; font-weight: 600; letter-spacing: -0.005em; }

  header { padding: 1.5rem 0 1rem 0; border-bottom: 1px solid var(--border); margin-bottom: 1rem; }
  h1 { margin: 0; font-size: 1.6rem; color: var(--purple); font-weight: 700; }
  h1 a { color: inherit; text-decoration: none; }
  .task-name { color: var(--accent); font-weight: 600; }
  nav a { color: var(--accent); text-decoration: none; margin-right: 1.25rem; font-weight: 500; }
  nav a:hover { text-decoration: underline; }

  h2 { margin: 2rem 0 0.5rem 0; font-size: 1.2rem; padding-bottom: 0.25rem; border-bottom: 1px solid var(--border); }
  h3 { margin: 1.25rem 0 0.5rem 0; font-size: 1rem; color: var(--muted); font-weight: 600; }

  .pass-meta {
    font-size: 0.85rem; color: var(--muted); display: flex; align-items: center; flex-wrap: wrap; gap: 0.5rem 1rem;
    margin: 1rem 0 0.5rem 0;
  }
  .pass-meta code { font-size: 0.85em; }
  .badge { display: inline-block; font-size: 0.75rem; padding: 0.1rem 0.5rem; border: 1px solid currentColor; }
  .badge-dirty { color: var(--dirty); background: var(--dirty-bg); }
  .badge-clean { color: var(--good); background: var(--good-bg); }

  .leaderboard-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-variant-numeric: tabular-nums; }
  th, td { padding: 0.5rem 0.7rem; text-align: left; border-bottom: 1px solid var(--border); vertical-align: middle; }
  th { font-weight: 600; font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; background: var(--surface); font-family: 'Montserrat', sans-serif; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; white-space: nowrap; }
  td.rank { font-weight: 600; color: var(--accent); width: 2.5rem; }
  tbody tr:hover { background: rgba(127,127,127,0.04); }
  tr.dirty { background: var(--dirty-bg); }
  tr.dirty td.rank { color: var(--dirty); }
  tr.dirty td.rank::before { content: "*"; }
  tr.tied td.rank::after { content: " ≈"; color: var(--tied); font-weight: normal; }

  .prov { display: inline-flex; align-items: center; gap: 0.5rem; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.9em; }
  .prov-swatch { display: inline-block; width: 8px; height: 8px; flex-shrink: 0; }
  .prov.provider-anthropic .prov-swatch { background: var(--prov-anthropic); }
  .prov.provider-openai .prov-swatch { background: var(--prov-openai); }
  .prov.provider-google .prov-swatch { background: var(--prov-google); }
  .prov.provider-xai .prov-swatch { background: var(--prov-xai); }
  .prov.provider-perplexity .prov-swatch { background: var(--prov-perplexity); }
  .prov.provider-openrouter .prov-swatch { background: var(--prov-openrouter); }

  .class-chip { display: inline-block; font-size: 0.66rem; padding: 0.05rem 0.35rem; margin-left: 0.5rem; letter-spacing: 0.5px; text-transform: uppercase; font-weight: 600; vertical-align: middle; }
  .class-chip.class-reasoning { color: var(--class-reasoning-fg); background: var(--class-reasoning-bg); }
  .class-chip.class-search { color: var(--class-search-fg); background: var(--class-search-bg); }
  .class-chip.class-standard { display: none; }

  .cost-cell { min-width: 9rem; }
  .cost-bar-wrap { display: flex; align-items: center; gap: 0.6rem; }
  .cost-bar { flex: 0 0 50px; height: 6px; background: var(--bar-bg); overflow: hidden; }
  .cost-bar > div { height: 100%; background: var(--bar-fill); }
  .cost-std { color: var(--muted); font-size: 0.85em; margin-left: 0.15rem; }

  .fm-list { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .fm-pill { display: inline-block; font-size: 0.72rem; padding: 0.1rem 0.4rem; background: rgba(127,127,127,0.1); color: var(--muted); white-space: nowrap; }
  .fm-pill strong { color: var(--fg); margin-right: 0.2rem; }

  .repro td.delta-up { color: var(--dirty); }
  .repro td.delta-down { color: var(--good); }
  .repro td.delta-flat { color: var(--muted); }

  /* Critique-Pass delta colors: positive cost delta = critique made it more
     expensive (red); positive success delta = critique improved accuracy (green).
     Methodology s13.3. */
  .critique td.delta-pos { color: var(--dirty); }
  .critique td.delta-neg { color: var(--good); }
  .critique td.delta-flat { color: var(--muted); }
  .critique-badge { background: var(--accent-soft); color: var(--accent); border: 1px solid var(--accent); }

  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.85rem; }
  footer a { color: var(--accent); text-decoration: none; }

  #theme-toggle {
    position: fixed; top: 0.75rem; right: 1rem;
    width: 30px; height: 30px;
    background: transparent; border: 1px solid var(--border);
    color: var(--muted); cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: color 0.15s ease, border-color 0.15s ease;
    padding: 0; z-index: 100;
  }
  #theme-toggle:hover { color: var(--fg); border-color: var(--border-strong); }
  #theme-toggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  #theme-toggle svg { display: none; width: 15px; height: 15px; }
  [data-theme="dark"] #theme-toggle .icon-sun { display: block; }
  [data-theme="light"] #theme-toggle .icon-moon { display: block; }

  @media (max-width: 640px) {
    body { padding: 0.75rem; }
    h1 { font-size: 1.3rem; }
    h2 { font-size: 1.1rem; }
    th, td { padding: 0.4rem 0.5rem; font-size: 0.88rem; }
  }
</style>
</head>
<body>

<button id="theme-toggle" type="button" aria-label="Toggle color scheme" title="Toggle color scheme">
  <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
  </svg>
  <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<header>
  <h1>
    <a href="../index.html">bellwether</a>
    &nbsp;&rsaquo;&nbsp;
    <span class="task-name"><code>{{ task_name }}</code></span>
  </h1>
  <nav>
    <a href="../index.html">All tasks</a>
    <a href="../methodology.html">Methodology</a>
    <a href="../glossary.html">Glossary</a>
    <a href="https://github.com/cartesianxr7/bellwether/tree/main/results">Raw results</a>
  </nav>
</header>

<main>

{% if view.critique_delta_rows %}
<h2>Critique-Pass delta (latest clean off vs latest clean on)</h2>
<p style="font-size: 0.85rem; color: var(--muted); margin: 0;">
  Per-model deltas between the critique-off baseline and the critique-on track per <a href="../methodology.html#13-critique-pass-evaluation-track-methodology-v02">METHODOLOGY s13.3</a>. Positive cost delta means the critique pass made it more expensive; positive success delta means it improved accuracy. Negative deltas are honestly reported.
</p>
<div class="leaderboard-wrap">
<table class="critique">
  <thead>
    <tr>
      <th>Provider / Model</th>
      <th class="num">Off eff_TCoT</th>
      <th class="num">On eff_TCoT</th>
      <th class="num">Δ eff_TCoT</th>
      <th class="num">Off success</th>
      <th class="num">On success</th>
      <th class="num">Δ success</th>
    </tr>
  </thead>
  <tbody>
    {% for d in view.critique_delta_rows %}
    <tr>
      <td><span class="prov provider-{{ d.provider }}"><span class="prov-swatch"></span>{{ d.provider }}/{{ d.model }}</span><span class="class-chip class-{{ d.model_class }}">{{ d.model_class }}</span></td>
      <td class="num">{% if d.off_effective_tcot_infinite %}infinite{% else %}${{ "%.5f"|format(d.off_effective_tcot) }}{% endif %}</td>
      <td class="num">{% if d.on_effective_tcot_infinite %}infinite{% else %}${{ "%.5f"|format(d.on_effective_tcot) }}{% endif %}</td>
      <td class="num {% if d.delta_eff_pct is none %}delta-flat{% elif d.delta_eff_pct > 1 %}delta-pos{% elif d.delta_eff_pct < -1 %}delta-neg{% else %}delta-flat{% endif %}">
        {% if d.delta_eff_pct is none %}n/a{% else %}{{ "%+.1f"|format(d.delta_eff_pct) }}%{% endif %}
      </td>
      <td class="num">{{ "%.1f"|format(d.off_success_rate * 100) }}%</td>
      <td class="num">{{ "%.1f"|format(d.on_success_rate * 100) }}%</td>
      <td class="num {% if d.delta_success_pp > 1 %}delta-neg{% elif d.delta_success_pp < -1 %}delta-pos{% else %}delta-flat{% endif %}">
        {{ "%+.1f"|format(d.delta_success_pp) }} pp
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% endif %}

{% if view.reproducibility %}
<h2>Reproducibility (latest pass vs previous)</h2>
<div class="leaderboard-wrap">
<table class="repro">
  <thead>
    <tr>
      <th>Provider / Model</th>
      <th class="num">Latest eff_TCoT</th>
      <th class="num">Previous eff_TCoT</th>
      <th class="num">Δ eff_TCoT</th>
      <th class="num">Δ success rate</th>
    </tr>
  </thead>
  <tbody>
    {% for r in view.reproducibility %}
    <tr>
      <td><span class="prov provider-{{ r.provider }}"><span class="prov-swatch"></span>{{ r.provider_model }}</span></td>
      <td class="num">${{ "%.5f"|format(r.latest_eff) if r.latest_eff is not none else "n/a" }}</td>
      <td class="num">${{ "%.5f"|format(r.previous_eff) if r.previous_eff is not none else "n/a" }}</td>
      <td class="num {% if r.delta_eff_pct is none %}delta-flat{% elif r.delta_eff_pct > 5 %}delta-up{% elif r.delta_eff_pct < -5 %}delta-down{% else %}delta-flat{% endif %}">
        {% if r.delta_eff_pct is none %}n/a{% else %}{{ "%+.1f"|format(r.delta_eff_pct) }}%{% endif %}
      </td>
      <td class="num {% if r.delta_success_pp > 1 %}delta-down{% elif r.delta_success_pp < -1 %}delta-up{% else %}delta-flat{% endif %}">
        {{ "%+.1f"|format(r.delta_success_pp) }} pp
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% endif %}

{% if view.failure_modes_aggregated %}
<h2>Failure-mode totals across all passes</h2>
<p style="font-size: 0.85rem; color: var(--muted); margin: 0;">Counts per failure mode summed across every attempt across every pass; useful for spotting which providers exhibit which failure patterns systematically.</p>
<div class="leaderboard-wrap">
<table>
  <thead>
    <tr>
      <th>Provider / Model</th>
      <th>Failure modes (total counts)</th>
    </tr>
  </thead>
  <tbody>
    {% for prov_model, modes in view.failure_modes_aggregated.items() %}
    {% set provider = prov_model.split('/')[0] %}
    <tr>
      <td><span class="prov provider-{{ provider }}"><span class="prov-swatch"></span>{{ prov_model }}</span></td>
      <td>
        {% if modes %}
        <span class="fm-list">
          {% for mode, count in modes.items()|sort(reverse=true, attribute=1) %}
          <span class="fm-pill"><strong>{{ count }}</strong>{{ mode }}</span>
          {% endfor %}
        </span>
        {% else %}
        <span style="color: var(--muted); font-size: 0.85rem;">none</span>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% endif %}

<h2>All bench passes (chronological, newest first)</h2>

{% for pass_data in view.passes %}
<div class="pass-meta">
  <strong>Pass {{ pass_data.started_at[:19].replace('T', ' ') }} UTC</strong>
  <code>{{ pass_data.git_sha_short }}</code>
  {% if pass_data.any_dirty %}
  <span class="badge badge-dirty">dirty tree, s9 non-headline</span>
  {% else %}
  <span class="badge badge-clean">clean</span>
  {% endif %}
  {% if pass_data.critique_pass %}
  <span class="badge critique-badge">critique-pass (s13)</span>
  {% endif %}
</div>

<div class="leaderboard-wrap">
<table>
  <thead>
    <tr>
      <th>#</th>
      <th>Provider / Model</th>
      <th class="num">Success</th>
      <th class="num">effective_TCoT</th>
      <th class="num">Latency p50 / p95</th>
      <th class="num">Attempts</th>
      <th>Failure modes (this pass)</th>
    </tr>
  </thead>
  <tbody>
    {% for entry in pass_data.entries %}
    <tr {% if entry.git_dirty %}class="dirty"{% elif entry.tied_with_above %}class="tied"{% endif %}>
      <td class="rank">{{ entry.rank }}</td>
      <td><span class="prov provider-{{ entry.provider }}"><span class="prov-swatch"></span>{{ entry.provider }}/{{ entry.model }}</span><span class="class-chip class-{{ entry.model_class }}">{{ entry.model_class }}</span></td>
      <td class="num">{{ "%.1f"|format(entry.success_rate * 100) }}% ({{ entry.n_successes }}/{{ entry.n_trials }})</td>
      <td class="num cost-cell">
        <div class="cost-bar-wrap">
          <span>
            {% if entry.effective_tcot_infinite %}infinite{% else %}${{ "%.5f"|format(entry.effective_tcot) }}{% endif %}{% if entry.std_tcot_success and not entry.effective_tcot_infinite %}<span class="cost-std">±${{ "%.5f"|format(entry.std_tcot_success) }}</span>{% endif %}
          </span>
          <div class="cost-bar"><div style="width: {{ entry.cost_bar_pct }}%"></div></div>
        </div>
      </td>
      <td class="num">{{ "%.2f"|format(entry.p50) }}s / {{ "%.2f"|format(entry.p95) }}s</td>
      <td class="num">{{ entry.n_attempts_total }} <span style="color: var(--muted); font-size: 0.8em;">({{ "%.0f"|format(entry.first_attempt_pass_rate * 100) }}% 1st-try)</span></td>
      <td>
        {% if entry.failure_mode_counts %}
        <span class="fm-list">
          {% for mode, count in entry.failure_mode_counts.items()|sort(reverse=true, attribute=1) %}
          <span class="fm-pill"><strong>{{ count }}</strong>{{ mode }}</span>
          {% endfor %}
        </span>
        {% else %}
        <span style="color: var(--muted); font-size: 0.85rem;">none</span>
        {% endif %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% endfor %}

</main>

<footer>
  <p>
    methodology version {{ methodology_version }}
    &middot; bellwether {{ bellwether_version }}
    &middot; <a href="../index.html">back to all tasks</a>
  </p>
</footer>

<script>
  document.getElementById('theme-toggle').addEventListener('click', function() {
    var root = document.documentElement;
    var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('bw-theme', next);
  });
</script>

</body>
</html>
